# ===========================================
# Hybrid Multi-Agent Routing
# ===========================================

# Classifier (determines: complex | high_volume | simple)
CLASSIFIER_PROVIDER=anthropic
CLASSIFIER_MODEL=claude-opus-4-6

# Data router (fetch_all/fetch/search)
ROUTER_PROVIDER=ollama
ROUTER_MODEL=

# Answer providers per task type (comma-separated fallback order)
SIMPLE_TASK_PROVIDER=ollama,anthropic
SIMPLE_TASK_MODEL=llama3.1:8b,claude-opus-4-6

HIGH_VOLUME_TASK_PROVIDER=ollama
HIGH_VOLUME_TASK_MODEL=llama3.1:8b

COMPLEX_TASK_PROVIDER=anthropic,deepseek,ollama
COMPLEX_TASK_MODEL=claude-opus-4-6,deepseek-chat,llama3.1:8b

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-opus-4-6

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=llama3.1:8b



# Token optimizations
MAX_OUTPUT_TOKENS=512
